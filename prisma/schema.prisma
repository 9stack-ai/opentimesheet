// 9stimesheet schema — covers ALL features (payout, profitability, billing) up front.
// SQLite (via @prisma/adapter-better-sqlite3). Money = integer VND dong; hours = Float.
// SQLite has no native enums → role/status are String (validated in app via Zod + lib/roles).
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String       @id @default(cuid())
  name                String
  email               String       @unique
  passwordHash        String?
  role                String       @default("FREELANCER") // ADMIN | MANAGER | FREELANCER
  status              String       @default("INVITED") // ACTIVE | INVITED | DISABLED
  defaultCostRate     Int          @default(0) // VND/hour — what we pay
  defaultBillableRate Int          @default(0) // VND/hour — what the client pays
  assignments         Assignment[]
  timeEntries         TimeEntry[]
  inviteToken         InviteToken?
  createdAt           DateTime     @default(now())
}

model Client {
  id        String    @id @default(cuid())
  name      String
  contact   String?
  notes     String?
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id          String       @id @default(cuid())
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id])
  name        String
  status      String       @default("ACTIVE") // ACTIVE | ARCHIVED
  startDate   DateTime?
  endDate     DateTime?
  tasks       Task[]
  assignments Assignment[]
  expenses    Expense[]
  createdAt   DateTime     @default(now())
}

model Task {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id])
  name        String
  status      String      @default("open")
  timeEntries TimeEntry[]
}

model Assignment {
  id                   String  @id @default(cuid())
  projectId            String
  userId               String
  costRateOverride     Int? // VND/hour, overrides User.defaultCostRate for this project
  billableRateOverride Int? // VND/hour, overrides User.defaultBillableRate for this project
  project              Project @relation(fields: [projectId], references: [id])
  user                 User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model TimeEntry {
  id                   String    @id @default(cuid())
  userId               String
  taskId               String
  date                 DateTime
  hours                Float
  note                 String?
  status               String    @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | REJECTED
  // Frozen at approval (rate snapshotting). All money reads use these, never live rates.
  costRateSnapshot     Int?
  billableRateSnapshot Int?
  rejectReason         String?
  approvedById         String?
  approvedAt           DateTime?
  user                 User      @relation(fields: [userId], references: [id])
  task                 Task      @relation(fields: [taskId], references: [id])
  createdAt            DateTime  @default(now())

  @@index([userId, date])
  @@index([status, date])
}

model Expense {
  id         String   @id @default(cuid())
  projectId  String? // null = company-level overhead
  category   String
  amount     Int // VND
  date       DateTime
  note       String?
  loggedById String
  project    Project? @relation(fields: [projectId], references: [id])
  createdAt  DateTime @default(now())
}

model FixedCost {
  id            String    @id @default(cuid())
  name          String
  category      String
  monthlyAmount Int // VND/month
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
}

model InviteToken {
  id        String    @id @default(cuid())
  userId    String    @unique
  selector  String    @unique // queryable lookup key (link = selector.verifier)
  tokenHash String // bcrypt hash of the verifier half
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
}
