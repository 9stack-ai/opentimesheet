// 9stimesheet schema — covers ALL features (payout, profitability, billing) up front.
// SQLite (via @prisma/adapter-better-sqlite3). Money = integer VND dong; hours = Float.
// SQLite has no native enums → role/status are String (validated in app via Zod + lib/roles).
// Keep field/constraint parity with prisma/schema.prod.prisma (comments may differ).
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String       @id @default(cuid())
  name                String
  email               String       @unique // login identifier (username)
  contactEmail        String? // contact email address (separate from login)
  passwordHash        String?
  role                String       @default("FREELANCER") // ADMIN | MANAGER | EMPLOYEE | FREELANCER
  status              String       @default("INVITED") // ACTIVE | INVITED | DISABLED
  defaultCostRate     Int          @default(0) // VND/hour — what we pay
  defaultBillableRate Int          @default(0) // VND/hour — what the client pays
  // Tax model (basis points; 10% = 1000). Withholding is deducted from gross pay; employer cost is added on top.
  taxWithholdingRateBps Int        @default(0) // PIT withheld from collaborator pay (e.g. 1000 = 10%)
  employerCostRateBps   Int        @default(0) // employer-side insurance, extra company cost (e.g. 2150 = 21.5%)
  // Redmine integration (single shared instance; API key encrypted at rest)
  redmineApiKeyEnc    String?
  redmineUserId       Int?
  redmineConnectedAt  DateTime?
  assignments         Assignment[]
  timeEntries         TimeEntry[]
  disbursements       Disbursement[]
  inviteToken         InviteToken?
  createdAt           DateTime     @default(now())
}

model Client {
  id        String    @id @default(cuid())
  name      String
  contact   String?
  notes     String?
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id               String       @id @default(cuid())
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id])
  name             String
  status           String       @default("ACTIVE") // ACTIVE | ARCHIVED
  redmineProjectId Int? // mapped Redmine project id (single shared instance)
  startDate        DateTime?
  endDate          DateTime?
  tasks            Task[]
  assignments      Assignment[]
  expenses         Expense[]
  createdAt        DateTime     @default(now())
}

model Task {
  id               String      @id @default(cuid())
  projectId        String
  project          Project     @relation(fields: [projectId], references: [id])
  name             String
  status           String      @default("open")
  // Redmine linkage (null for local tasks)
  source           String      @default("LOCAL") // LOCAL | REDMINE
  redmineIssueId   Int?
  redmineUpdatedOn DateTime?
  redmineClosed    Boolean     @default(false)
  syncedAt         DateTime?
  timeEntries      TimeEntry[]

  @@unique([projectId, redmineIssueId])
}

model Assignment {
  id                   String  @id @default(cuid())
  projectId            String
  userId               String
  costRateOverride     Int? // VND/hour, overrides User.defaultCostRate for this project
  billableRateOverride Int? // VND/hour, overrides User.defaultBillableRate for this project
  project              Project @relation(fields: [projectId], references: [id])
  user                 User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model TimeEntry {
  id                   String    @id @default(cuid())
  userId               String
  taskId               String
  date                 DateTime
  hours                Float
  note                 String?
  status               String    @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | REJECTED
  // Frozen at approval (rate snapshotting). All money reads use these, never live rates.
  costRateSnapshot     Int?
  billableRateSnapshot Int?
  // Tax rates frozen at approval (basis points). null on legacy rows → treated as 0.
  taxRateSnapshot      Int?
  employerCostRateSnapshot Int?
  rejectReason         String?
  approvedById         String?
  approvedAt           DateTime?
  // Redmine push (app time entry -> Redmine time entry)
  redmineTimeEntryId   Int?
  redminePushStatus    String    @default("pending") // pending | pushing | pushed | failed | skipped
  redminePushedAt      DateTime?
  redminePushError     String?
  user                 User      @relation(fields: [userId], references: [id])
  task                 Task      @relation(fields: [taskId], references: [id])
  createdAt            DateTime  @default(now())

  @@index([userId, date])
  @@index([status, date])
  @@index([redminePushStatus])
}

model Expense {
  id         String   @id @default(cuid())
  projectId  String? // null = company-level overhead
  category   String
  kind       String   @default("REGULAR") // REGULAR | IRREGULAR (chi bất thường)
  amount     Int // VND
  date       DateTime
  note       String?
  loggedById String
  project    Project? @relation(fields: [projectId], references: [id])
  createdAt  DateTime @default(now())
}

model Income {
  id         String    @id @default(cuid())
  source     String // tên nguồn thu (góp vốn, tạm ứng, doanh thu…)
  amount     Int // VND
  date       DateTime? // null = chưa gán kỳ (nhập sau)
  note       String?
  loggedById String
  createdAt  DateTime  @default(now())
}

// Actual money paid out to a person (thực chi), distinct from timesheet-derived payout
// (which is only a record/accrual). periodLabel = the salary month it settles ("YYYY-MM").
model Disbursement {
  id          String   @id @default(cuid())
  userId      String
  amount      Int // VND actually paid
  date        DateTime // payment date
  periodLabel String // "YYYY-MM" salary month settled
  note        String?
  loggedById  String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([periodLabel])
}

model FixedCost {
  id            String    @id @default(cuid())
  name          String
  category      String
  monthlyAmount Int // VND/month
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
}

model InviteToken {
  id        String    @id @default(cuid())
  userId    String    @unique
  selector  String    @unique // queryable lookup key (link = selector.verifier)
  tokenHash String // bcrypt hash of the verifier half
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
}
