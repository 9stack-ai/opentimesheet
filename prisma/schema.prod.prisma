// PRODUCTION schema — PostgreSQL. Field/constraint parity with prisma/schema.prisma
// (SQLite dev); only the datasource provider differs. Provisioned with:
//   prisma db push --schema=prisma/schema.prod.prisma
// Keep this file's FIELDS in sync with prisma/schema.prisma whenever models change.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String       @id @default(cuid())
  name                String
  email               String       @unique // login identifier (username)
  contactEmail        String? // contact email address (separate from login)
  passwordHash        String?
  role                String       @default("FREELANCER") // ADMIN | MANAGER | EMPLOYEE | FREELANCER
  status              String       @default("INVITED") // ACTIVE | INVITED | DISABLED
  defaultCostRate     Int          @default(0)
  defaultBillableRate Int          @default(0)
  taxWithholdingRateBps Int        @default(0)
  employerCostRateBps   Int        @default(0)
  redmineApiKeyEnc    String?
  redmineUserId       Int?
  redmineConnectedAt  DateTime?
  assignments         Assignment[]
  timeEntries         TimeEntry[]
  disbursements       Disbursement[]
  workSession         WorkSession?
  inviteToken         InviteToken?
  createdAt           DateTime     @default(now())
}

model Client {
  id        String    @id @default(cuid())
  name      String
  contact   String?
  notes     String?
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id               String       @id @default(cuid())
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id])
  name             String
  status           String       @default("ACTIVE")
  redmineProjectId Int?
  startDate        DateTime?
  endDate          DateTime?
  tasks            Task[]
  assignments      Assignment[]
  expenses         Expense[]
  incomes          Income[]
  createdAt        DateTime     @default(now())
}

model Task {
  id               String      @id @default(cuid())
  projectId        String
  project          Project     @relation(fields: [projectId], references: [id])
  name             String
  status           String      @default("open")
  source           String      @default("LOCAL") // LOCAL | REDMINE
  redmineIssueId   Int?
  redmineUpdatedOn DateTime?
  redmineClosed    Boolean     @default(false)
  syncedAt         DateTime?
  timeEntries      TimeEntry[]

  @@unique([projectId, redmineIssueId])
}

model Assignment {
  id                   String  @id @default(cuid())
  projectId            String
  userId               String
  costRateOverride     Int?
  billableRateOverride Int?
  project              Project @relation(fields: [projectId], references: [id])
  user                 User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model TimeEntry {
  id                   String    @id @default(cuid())
  userId               String
  taskId               String
  date                 DateTime
  hours                Float
  note                 String?
  status               String    @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | REJECTED
  costRateSnapshot     Int?
  billableRateSnapshot Int?
  taxRateSnapshot      Int?
  employerCostRateSnapshot Int?
  rejectReason         String?
  approvedById         String?
  approvedAt           DateTime?
  redmineTimeEntryId   Int?
  redminePushStatus    String    @default("pending") // pending | pushing | pushed | failed | skipped
  redminePushedAt      DateTime?
  redminePushError     String?
  user                 User      @relation(fields: [userId], references: [id])
  task                 Task      @relation(fields: [taskId], references: [id])
  createdAt            DateTime  @default(now())

  @@index([userId, date])
  @@index([status, date])
  @@index([redminePushStatus])
}

model Expense {
  id         String   @id @default(cuid())
  projectId  String?
  category   String
  kind       String   @default("REGULAR") // REGULAR | IRREGULAR
  amount     Int
  date       DateTime
  note       String?
  loggedById String
  project    Project? @relation(fields: [projectId], references: [id])
  createdAt  DateTime @default(now())
}

model Income {
  id         String    @id @default(cuid())
  source     String // tên nguồn thu (góp vốn, tạm ứng, doanh thu…)
  projectId  String? // null = không gắn dự án (thu cấp công ty)
  amount     Int // VND
  date       DateTime? // null = chưa gán kỳ (nhập sau)
  note       String?
  loggedById String
  project    Project?  @relation(fields: [projectId], references: [id])
  createdAt  DateTime  @default(now())
}

// Actual money paid out to a person (thực chi), distinct from timesheet-derived payout
// (which is only a record/accrual). periodLabel = the salary month it settles ("YYYY-MM").
model Disbursement {
  id          String   @id @default(cuid())
  userId      String
  amount      Int // VND actually paid
  date        DateTime // payment date
  periodLabel String // "YYYY-MM" salary month settled
  note        String?
  loggedById  String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([periodLabel])
}

// Audit trail: who did what, when. actorName is denormalized so a log survives
// the actor's deletion; details is a human-readable Vietnamese summary.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // null if the actor was deleted/system
  actorName  String
  actorRole  String
  action     String // machine code, e.g. "timeentry.create"
  summary    String // human-readable summary
  targetType String?
  targetId   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
}

model FixedCost {
  id            String    @id @default(cuid())
  name          String
  category      String
  monthlyAmount Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
}

model InviteToken {
  id        String    @id @default(cuid())
  userId    String    @unique
  selector  String    @unique
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
}

// Phiên làm việc đang chạy của CTV (start/stop). userId @unique → tối đa 1 phiên mở/người.
model WorkSession {
  id        String   @id @default(cuid())
  userId    String   @unique
  startedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
